    "assets/js/admin-script.js",
    "templates/page-builder/template-landing.php",
    "templates/page-builder/template-blog.php",
    "templates/page-builder/template-auth.php"
  ],
  "install": [],
  "env": {
    "DB_HOST":             "Your database host (e.g. localhost)",
    "DB_NAME":             "Your database name",
    "DB_USER":             "Your database user",
    "DB_PASSWORD":         "Your database password",
    "AI_API_KEY":          "Your OpenAI API key — enter in plugin Admin > AI Settings",
    "GITHUB_AI_API_KEY":   "Your GitHub AI API key — enter in plugin Admin > AI Settings",
    "JWT_SECRET":          "Auto-generated on activation; override in Admin > SSO Settings",
    "CHILLIES_COOKIE_DOMAIN": ".greenchilliesent.com"
